{% extends 'base.html.twig' %}

{% block title %}Kudos index{% endblock %}

{% block body %}
    <h1>Kudos index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>MsgContent</th>
                <th>CreatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for kudo in kudos %}
            <tr>
                <td>{{ kudo.id }}</td>
                <td>{{ kudo.msgContent }}</td>
                <td>{{ kudo.createdAt ? kudo.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_kudos_show', {'id': kudo.id}) }}">show</a>
                    <a href="{{ path('app_kudos_edit', {'id': kudo.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_kudos_new') }}">Create new</a>
{% endblock %}
